# Third-party services for HenryCo web apps
# Keep secrets in Vercel or local .env.local only. Do not commit real values here.

# Client-safe
NEXT_PUBLIC_GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key
NEXT_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id
NEXT_PUBLIC_ONESIGNAL_SAFARI_WEB_ID=your_onesignal_safari_web_id
NEXT_PUBLIC_TYPESENSE_HOST=your-typesense-cluster.a1.typesense.net
NEXT_PUBLIC_TYPESENSE_PORT=443
NEXT_PUBLIC_TYPESENSE_PROTOCOL=https
NEXT_PUBLIC_TYPESENSE_NODES=your-typesense-cluster-1.a1.typesense.net:443,your-typesense-cluster-2.a1.typesense.net:443,your-typesense-cluster-3.a1.typesense.net:443
NEXT_PUBLIC_TYPESENSE_SEARCH_API_KEY=your_typesense_search_only_key
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_access_token
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
NEXT_PUBLIC_SENTRY_DSN=https://public_dsn@example.ingest.sentry.io/project_id
NEXT_PUBLIC_FINGERPRINTJS_API_KEY=your_fingerprintjs_public_api_key
NEXT_PUBLIC_FINGERPRINTJS_REGION=eu

# Server-only
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_NAME=HenryCo
BREVO_SENDER_EMAIL=noreply@henrycogroup.com
BREVO_REPLY_TO_EMAIL=support@henrycogroup.com
OWNER_ALERT_EMAIL=owner@henrycogroup.com
MARKETPLACE_OWNER_ALERT_EMAIL=marketplace-owner@henrycogroup.com
MARKETPLACE_SENDER_EMAIL=marketplace@henrycogroup.com
DEEPL_API_KEY=your_deepl_api_key
TYPESENSE_ADMIN_API_KEY=your_typesense_admin_api_key
TYPESENSE_SEARCH_API_KEY=your_optional_server_search_api_key
TYPESENSE_HOST=your-typesense-cluster.a1.typesense.net
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_NODES=your-typesense-cluster-1.a1.typesense.net:443,your-typesense-cluster-2.a1.typesense.net:443,your-typesense-cluster-3.a1.typesense.net:443
SIGNWELL_API_KEY=your_signwell_api_key
MAPBOX_SECRET_TOKEN=your_mapbox_secret_token
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_API_KEY_SID=your_twilio_api_key_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+2340000000000
STRIPE_SECRET_KEY=sk_test_your_secret_key
SENTRY_DSN=https://public_dsn@example.ingest.sentry.io/project_id
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=henryco
SENTRY_PROJECT=javascript-nextjs
OPENRATE_APP_ID=your_openrate_app_id
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_api_key
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key

# Inbound company-mail routing
# Outbound email is now Brevo. Inbound can stay on the current provider until Brevo inbound parsing is fully provisioned.
INBOUND_EMAIL_PROVIDER=resend
INBOUND_EMAIL_API_KEY=your_inbound_provider_api_key
INBOUND_EMAIL_WEBHOOK_SECRET=your_inbound_provider_webhook_secret
INBOUND_SUPPORT_INBOX=support@henrycogroup.com

