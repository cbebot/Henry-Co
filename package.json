{
  "name": "henryco-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare": "husky",
    "guardrails:repo": "node ./scripts/ci/repo-guardrails.mjs --mode=repo",
    "guardrails:staged": "node ./scripts/ci/repo-guardrails.mjs --mode=staged",
    "migrations:validate": "node ./scripts/ci/validate-migrations.mjs",
    "migrations:validate:strict": "node ./scripts/ci/validate-migrations.mjs --strict",
    "build:all": "pnpm -r --filter \"./apps/*\" run build",
    "lint:all": "pnpm -r --filter \"./apps/*\" run lint",
    "typecheck:all": "pnpm -r --filter \"./apps/*\" run typecheck",
    "test:workspace": "pnpm --filter @henryco/super-app run test:ci",
    "ci:validate": "pnpm run guardrails:repo && pnpm run migrations:validate && pnpm run lint:all && pnpm run typecheck:all && pnpm run test:workspace && pnpm run build:all",
    "build:logistics": "pnpm --filter @henryco/logistics build",
    "lint:logistics": "pnpm --filter @henryco/logistics lint",
    "typecheck:logistics": "pnpm --filter @henryco/logistics typecheck",
    "build:studio": "pnpm --filter @henryco/studio build",
    "lint:studio": "pnpm --filter @henryco/studio lint",
    "typecheck:studio": "pnpm --filter @henryco/studio typecheck",
    "super-app:start": "pnpm --filter @henryco/super-app start",
    "super-app:lint": "pnpm --filter @henryco/super-app lint",
    "super-app:typecheck": "pnpm --filter @henryco/super-app typecheck",
    "super-app:test": "pnpm --filter @henryco/super-app test:ci",
    "company-hub:start": "pnpm --filter @henryco/company-hub start",
    "company-hub:lint": "pnpm --filter @henryco/company-hub lint",
    "company-hub:typecheck": "pnpm --filter @henryco/company-hub typecheck",
    "staff:dev": "pnpm --filter @henryco/staff dev",
    "staff:build": "pnpm --filter @henryco/staff build",
    "staff:lint": "pnpm --filter @henryco/staff lint",
    "staff:typecheck": "pnpm --filter @henryco/staff typecheck"
  },
  "dependencies": {
    "@henryco/config": "workspace:^"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "next": "16.1.6"
  }
}
