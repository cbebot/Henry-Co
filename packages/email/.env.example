# ─────────────────────────────────────────────────────────────────────────────
# @henryco/email — outbound email configuration (EMAIL-POSTMARK, 2026-07-14)
# ─────────────────────────────────────────────────────────────────────────────
# Postmark is the ONLY outbound rail. Amazon SES / Resend / Brevo are retired.
#
# POSTMARK_SERVER_TOKEN is set in the SHARED environment variables system
# (Vercel team env / Doppler / Infisical / AWS SSM — whatever the org uses).
# After merge it will automatically sync to every subdomain deployment — do NOT
# duplicate it per app, do NOT create per-subdomain secrets, and NEVER commit
# real values.

# ── Required: the single Postmark Server API token ───────────────────────────
# ONE Server token unlocks EVERY Message Stream on that Postmark Server, so this
# single secret covers all divisions and every subdomain. POSTMARK_API_TOKEN is
# accepted as an alias. When unset, sends are skipped gracefully (no crash).
POSTMARK_SERVER_TOKEN=

# ── Optional: global sender + default stream ─────────────────────────────────
# Fallback From used when a per-division alias below is not set. Must be a
# Postmark-verified sender on the henryonyx.com sending domain (SPF/DKIM green).
POSTMARK_FROM_EMAIL="Henry Onyx <noreply@henryonyx.com>"
# Overrides the built-in "outbound" transactional stream. Set this to
# "transactional" only if you created a Message Stream with that exact ID.
POSTMARK_MESSAGE_STREAM=

# ── Per-division branded From identities (all @henryonyx.com) ─────────────────
# Each `purpose` resolves its From from these; unset falls back to
# POSTMARK_FROM_EMAIL with the branded display name preserved. Every var has an
# optional matching *_FROM_NAME (e.g. HENRYCO_CARE_FROM_NAME="Henry Onyx Care").
# The "→ stream" comments show which purposes ride a dedicated Message Stream.
HENRYCO_NOREPLY_EMAIL="noreply@henryonyx.com"
HENRYCO_NOREPLY_FROM_NAME="Henry Onyx"
HENRYCO_ACCOUNTS_EMAIL="accounts@henryonyx.com"      # auth: signup, recovery, magic links
HENRYCO_SUPPORT_EMAIL="support@henryonyx.com"
HENRYCO_CARE_EMAIL="care@henryonyx.com"              # → stream: fabric-care
HENRYCO_STUDIO_EMAIL="studio@henryonyx.com"          # → stream: studio-notifications
HENRYCO_MARKETPLACE_EMAIL="marketplace@henryonyx.com"
HENRYCO_JOBS_EMAIL="jobs@henryonyx.com"
HENRYCO_LEARN_EMAIL="learn@henryonyx.com"
HENRYCO_PROPERTY_EMAIL="property@henryonyx.com"      # → stream: property-inquiries
HENRYCO_LOGISTICS_EMAIL="logistics@henryonyx.com"
HENRYCO_SECURITY_EMAIL="security@henryonyx.com"      # → stream: software-alerts
HENRYCO_NEWSLETTER_EMAIL="editorial@henryonyx.com"   # → stream: marketing-broadcast (broadcast type)

# ─────────────────────────────────────────────────────────────────────────────
# RETIRED — do NOT set (tombstone so nobody re-introduces a dead rail):
#   AWS_SES_ACCESS_KEY_ID · AWS_SES_SECRET_ACCESS_KEY · AWS_SES_REGION
#   AWS_SES_FROM_EMAIL · AWS_SES_SESSION_TOKEN · AWS_ACCESS_KEY_ID (email use)
#   AWS_SECRET_ACCESS_KEY (email use) · EMAIL_PROVIDER · EMAIL_FALLBACK_PROVIDER
#   RESEND_API_KEY (outbound) · BREVO_API_KEY · BREVO_SENDER_EMAIL
#
# NOTE: inbound reply-receiving (support threads) still uses RESEND_* / INBOUND_*
# — that is a SEPARATE rail (mail coming IN, not going OUT) and is intentionally
# NOT migrated here.
# ─────────────────────────────────────────────────────────────────────────────
