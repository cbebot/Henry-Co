# Staging-only template for Expo / EAS (copy to EAS secrets or local `.env.staging.local`; never commit real keys).
# Use a non-production Supabase project and sandbox payment/monitoring projects only.

EXPO_PUBLIC_HENRYCO_ENV=staging
EXPO_PUBLIC_APP_ENV=staging
EXPO_PUBLIC_LIVE_SERVICES_APPROVED=false

# Supabase (staging project — anon key only in client)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Cloudinary (staging folder or same cloud with staging path prefix)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_BASE_PATH=henryco/staging

# Monitoring (staging DSN / separate Sentry project)
EXPO_PUBLIC_SENTRY_DSN=

EXPO_PUBLIC_WEB_ORIGIN=https://staging.henrycogroup.com

# Feature flags — connect one service at a time; see docs/staging-validation.md
# EXPO_PUBLIC_FEATURE_REMOTE_DATABASE=true
# EXPO_PUBLIC_FEATURE_LIVE_MONITORING=true
# EXPO_PUBLIC_FEATURE_LIVE_PUSH=true
# EXPO_PUBLIC_FEATURE_PAYMENTS=true
# EXPO_PUBLIC_FEATURE_MEDIA_UPLOAD=false
# EXPO_PUBLIC_FEATURE_PAYMENTS_DEMO=false
# EXPO_PUBLIC_FEATURE_RUNTIME_DIAGNOSTICS=true
