{
  "expo": {
    "name": "HenryCo",
    "slug": "henryco-super-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "henryco",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0C"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "bundleIdentifier": "com.henryco.superapp.staging",
      "associatedDomains": [
        "applinks:staging.henryonyx.com",
        "applinks:account.henryonyx.com",
        "applinks:care.henryonyx.com",
        "applinks:marketplace.henryonyx.com",
        "applinks:property.henryonyx.com",
        "applinks:jobs.henryonyx.com",
        "applinks:learn.henryonyx.com",
        "applinks:logistics.henryonyx.com",
        "applinks:studio.henryonyx.com",
        "applinks:building.henryonyx.com",
        "applinks:hotel.henryonyx.com",
        "webcredentials:account.henryonyx.com"
      ]
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0B0C"
      },
      "package": "com.henryco.superapp.staging",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "staging.henryonyx.com", "pathPrefix": "/app" },
            { "scheme": "https", "host": "account.henryonyx.com" },
            { "scheme": "https", "host": "care.henryonyx.com" },
            { "scheme": "https", "host": "marketplace.henryonyx.com" },
            { "scheme": "https", "host": "property.henryonyx.com" },
            { "scheme": "https", "host": "jobs.henryonyx.com" },
            { "scheme": "https", "host": "learn.henryonyx.com" },
            { "scheme": "https", "host": "logistics.henryonyx.com" },
            { "scheme": "https", "host": "studio.henryonyx.com" },
            { "scheme": "https", "host": "building.henryonyx.com" },
            { "scheme": "https", "host": "hotel.henryonyx.com" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "replace-with-staging-eas-project-id"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
