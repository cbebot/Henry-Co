# Copy to `.env.local` for local Expo (never commit real secrets).
# See `src/platform/config/*.ts` and `docs/SERVICE_MIGRATION_CHECKLIST.md`.

# --- Runtime (canonical) ---
# local | staging | production
# Omit to auto-detect: __DEV__ → local, release → staging
EXPO_PUBLIC_HENRYCO_ENV=local

# Production only: must be "true" to enable live adapters (payments, remote DB, monitoring, etc.)
EXPO_PUBLIC_LIVE_SERVICES_APPROVED=false

# Legacy label used by some tooling; keep aligned with HENRYCO_ENV when possible
EXPO_PUBLIC_APP_ENV=development

# --- Supabase (staging / production; optional for local if EXPO_PUBLIC_FEATURE_REMOTE_DATABASE=true) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Cloudinary (read-only URLs work without upload keys) ---
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=dhueyqvid
EXPO_PUBLIC_CLOUDINARY_BASE_PATH=henryco

# --- Monitoring ---
EXPO_PUBLIC_SENTRY_DSN=

# --- Web / deep links ---
EXPO_PUBLIC_WEB_ORIGIN=https://www.henrycogroup.com

# --- Per-feature overrides (optional; defaults come from mode in featureFlags.ts) ---
# EXPO_PUBLIC_FEATURE_PAYMENTS=false
# EXPO_PUBLIC_FEATURE_ANALYTICS=false
# EXPO_PUBLIC_FEATURE_LIVE_PUSH=false
# EXPO_PUBLIC_FEATURE_LIVE_MONITORING=false
# EXPO_PUBLIC_FEATURE_REMOTE_DATABASE=false
# EXPO_PUBLIC_FEATURE_MEDIA_UPLOAD=false
