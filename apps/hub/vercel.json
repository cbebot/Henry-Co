{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "hq.henrycogroup.com"
        }
      ],
      "destination": "/owner"
    },
    {
      "source": "/:path((?!(?:owner|api)(?:/|$)).*)",
      "has": [
        {
          "type": "host",
          "value": "hq.henrycogroup.com"
        }
      ],
      "destination": "/owner/:path*"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "workspace.henrycogroup.com"
        }
      ],
      "destination": "/workspace"
    },
    {
      "source": "/:path((?!(?:workspace|api)(?:/|$)).*)",
      "has": [
        {
          "type": "host",
          "value": "workspace.henrycogroup.com"
        }
      ],
      "destination": "/workspace/:path*"
    }
  ]
}
