# ── Henry & Co. Owner CMS — environment ───────────────────────────────────────
# All secrets are injected via the Vercel project (set for ALL environments to
# avoid the known preview-env 500 gap). Never commit real values.

# Supabase — SAME project as the hub (the CMS edits real, live content)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only; bypasses RLS — never client-exposed

# Cloudinary — server-only; signed media uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=                # server-only

# DeepL — server-only; downstream translation pipeline
DEEPL_API_KEY=

# Upstash Redis — server-only; OTP send + verify rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Observability (optional)
NEXT_PUBLIC_SENTRY_DSN=

# App
NEXT_PUBLIC_SITE_URL=                 # e.g. https://henryco-cms.vercel.app
