{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @henryco/jobs build",
  "crons": [
    {
      "path": "/api/cron/jobs-alerts",
      "schedule": "0 * * * *"
    }
  ]
}
