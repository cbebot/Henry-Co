{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @henryco/logistics build",
  "crons": [
    {
      "path": "/api/cron/logistics-automation",
      "schedule": "*/15 * * * *"
    }
  ]
}
