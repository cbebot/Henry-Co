# Copy to `.env.local` for local Expo (never commit real secrets).
# The company-hub Expo app currently has minimal env surface — only the
# brand-domain override is consumed today (PROD-READY-01).

# --- Brand domain ---
# Bare base domain used by the directory catalog (https://<sub>.<basedomain>)
# and the legal-page brand display strings.
# Leave unset to keep the historical default `henrycogroup.com`. Set when
# the company moves to a new brand TLD so a fresh build picks up the change
# without any code edits.
EXPO_PUBLIC_BASE_DOMAIN=
