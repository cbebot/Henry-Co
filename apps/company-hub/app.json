{
  "expo": {
    "name": "Henry Onyx Hub",
    "slug": "henryco-company-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "henrycohub",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1510"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.henryco.hub",
      "associatedDomains": [
        "applinks:hq.henryonyx.com",
        "applinks:staff.henryonyx.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Used for profile and content features in future updates.",
        "NSPhotoLibraryUsageDescription": "Used to select images for profile and content features."
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1A1510"
      },
      "package": "com.henryco.hub",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "hq.henryonyx.com" },
            { "scheme": "https", "host": "staff.henryonyx.com" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A1510",
          "image": "./assets/splash.png",
          "imageWidth": 240
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
