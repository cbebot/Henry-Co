# Marketplace local env template
# Copy to .env.local, .env.production.local, or use .vercel/.env.production.local.
# Do not commit populated env files.

NEXT_PUBLIC_BASE_DOMAIN=henrycogroup.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_FOLDER=marketplace
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Marketplace <hello@henrycogroup.com>
RESEND_SUPPORT_INBOX=support@henrycogroup.com
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

CRON_SECRET=your-marketplace-cron-secret
