{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @henryco/care build",
  "crons": [
    {
      "path": "/api/cron/care-automation",
      "schedule": "15 8 * * *"
    }
  ]
}
