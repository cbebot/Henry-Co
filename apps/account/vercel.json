{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @henryco/account build",
  "crons": [
    {
      "path": "/api/cron/notification-email-fallback",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/notification-purge",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/engagement-sweep",
      "schedule": "13 * * * *"
    },
    {
      "path": "/api/cron/notification-redelivery",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/recovery-sweep",
      "schedule": "37 */6 * * *"
    },
    {
      "path": "/api/cron/kyc-retention",
      "schedule": "41 4 * * *"
    }
  ]
}
